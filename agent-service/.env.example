# LLM 端点（任意 OpenAI 兼容端点：GPT 代理 / DeepSeek / 其它）
LLM_API_KEY=replace-with-your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4

# 质量门槛（对应约束手册 6.1 评分等级：S=90 A=80 B=70 C=60）
MIN_PASS_SCORE=80
MAX_REVISE_ROUNDS=2

# 批量生成并发上限
MAX_CONCURRENCY=5

# 单次 /generate-reviews 整批生成超时；超时会返回 504 并写 agent_generation_timeout 日志
AGENT_GENERATION_TIMEOUT_SECONDS=240

# 服务监听
AGENT_HOST=127.0.0.1
AGENT_PORT=8090

# Go backend 调用 /generate-reviews 时必须发送：
# X-Agent-Internal-Token: replace-with-shared-internal-token
AGENT_INTERNAL_TOKEN=replace-with-shared-internal-token
