# Deployment entrypoint:
#   scripts/deploy.sh start
#
# The public service listens on FRONTEND_PORT only. The Go backend and
# agent-service are bound to localhost and reached through the gateway.

APP_ENV=production

# Public gateway/frontend.
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8989
# Optional, for example: http://your-server-ip:8989
PUBLIC_ORIGIN=

# Local-only Go backend.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=18989

# Local-only Python agent-service.
AGENT_HOST=127.0.0.1
AGENT_PORT=8090
AGENT_SERVICE_URL=http://127.0.0.1:8090

# Use strong values in production. If these are omitted, scripts/deploy.sh
# generates JWT_SECRET and AGENT_INTERNAL_TOKEN in .deploy/runtime.env.
JWT_SECRET=
AGENT_INTERNAL_TOKEN=

# MySQL. Set MYSQL_DSN directly, or leave it empty and set DB_APP_PASSWORD
# so scripts/deploy.sh can build the DSN from DB_* values.
MYSQL_DSN=

# Optional DB initialization.
INIT_DB=false
LOAD_SEED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=
DB_NAME=ppk
DB_APP_USER=ppk_app
# MySQL account host for the app user. Use the backend host as seen by MySQL;
# for local single-server MySQL this is usually 127.0.0.1.
DB_APP_HOST=127.0.0.1
DB_APP_PASSWORD=

# LLM endpoint used by agent-service.
LLM_API_KEY=
# Set to true only when you want to start the UI/API without AI generation.
ALLOW_EMPTY_LLM_KEY=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4
MIN_PASS_SCORE=80
MAX_REVISE_ROUNDS=2
MAX_CONCURRENCY=5

# Go backend generation behavior.
AGENT_MIN_GRADE=B
MAX_REVIEW_GENERATE_COUNT=50
DEFAULT_REVIEW_TARGET_COUNT=10

# Deployment smoke test. When LOAD_SEED=true, default admin/merchant
# authenticated checks are run through http://127.0.0.1:8989/api.
SMOKE_TEST=true
SMOKE_TEST_AUTH=auto
SMOKE_ADMIN_ACCOUNT=admin
SMOKE_ADMIN_PASSWORD=123456
SMOKE_MERCHANT_ACCOUNT=merchant
SMOKE_MERCHANT_PASSWORD=123456
